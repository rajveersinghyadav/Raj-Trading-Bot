const config = require('../config');

async function getAllMarketData() {
    console.log("Fetching data for all assets...");
    let marketData = {};
    
    for (let asset of config.ASSETS) {
        // Yahan har asset ke liye data fetch hoga
        marketData[asset] = { price: 2000, volume: 500 }; 
    }
    return marketData;
}

module.exports = { getAllMarketData };
